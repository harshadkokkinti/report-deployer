# GitHub — create a Personal Access Token with repo scope
# https://github.com/settings/tokens/new
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your-github-username
GITHUB_REPO=report-deployer

# The public URL of your deployment (no trailing slash)
SITE_URL=https://your-project.vercel.app

# Admin dashboard credentials (required)
ADMIN_USER=admin
ADMIN_PASS=change-me-in-production

# Secret path for the admin dashboard — set to a hard-to-guess string (e.g. a random slug)
# Access: https://your-domain.com/<ADMIN_PATH>
ADMIN_PATH=your-secret-path

# Local dev only
PORT=3000
