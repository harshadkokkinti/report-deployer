<%
function ratingColor(r) {
  return r < 3.5 ? '#C9274A' : r <= 4.0 ? '#D4890A' : '#0FA88A';
}
function verdictColor(v) {
  return v === 'Critical' ? '#C9274A' : v === 'Watch' ? '#D4890A' : '#0FA88A';
}
function statColor(t) {
  return t === 'bad' ? '#C9274A' : t === 'warn' ? '#D4890A' : t === 'ok' ? '#0FA88A' : '#C2C2D8';
}
function severityColor(s) {
  return s === 'red' ? '#C9274A' : s === 'amber' ? '#D4890A' : s === 'purple' ? '#8B3FD9' : '#3B7BE8';
}
function dowBarClass(pct) {
  if (dowRange === 0) return 'low';
  var n = (pct - minDow) / dowRange;
  return n >= 0.67 ? 'high' : n >= 0.34 ? 'mid' : 'low';
}
function reviewBorderColor(rating) {
  return rating <= 2 ? 'rgba(201,39,74,0.35)' : rating === 3 ? 'rgba(212,137,10,0.35)' : 'rgba(59,123,232,0.35)';
}
function reviewRatingColor(rating) {
  return rating <= 2 ? '#C9274A' : rating === 3 ? '#D4890A' : '#0FA88A';
}
function scoreNote(score) {
  if (score >= 90) return 'Exceptional customer satisfaction with minimal negative feedback and strong engagement.';
  if (score >= 80) return 'Strong reputation with consistent positive feedback and clear areas to optimize.';
  if (score >= 70) return 'Solid foundation with actionable gaps. Focus on recurring complaint themes.';
  return 'Significant reputation gaps require immediate attention across multiple complaint categories.';
}
var vc = verdictColor(d.olly_verdict);
var rc = ratingColor(d.avg_rating);
var ring = 'conic-gradient(' + vc + ' 0% ' + d.olly_score + '%, #191C38 ' + d.olly_score + '% 100%)';
var dowPcts = d.dow_breakdown.map(function(x){ return x.complaint_pct; });
var maxDow = Math.max.apply(null, dowPcts);
var minDow = Math.min.apply(null, dowPcts);
var dowRange = maxDow - minDow;
var showDow = dowRange >= 2;
var showMenu = Array.isArray(d.menu_complaints) && d.menu_complaints.length > 0;
var maxCat = d.complaint_categories.length ? Math.max.apply(null, d.complaint_categories.map(function(x){ return x.count; })) : 1;
var dc = d.dynamic_copy;
%><!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= d.brand_name %> Reputation Report by Olly</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --bg:#08091A;--bg1:#0D0F24;--bg2:#13162E;--bg3:#191C38;
      --text:#F0EFFF;--text2:#C2C2D8;--text3:#8A8AA6;
      --blue:#3B7BE8;--blue-light:#6FA3FF;
      --blue-bg:rgba(59,123,232,0.1);--blue-border:rgba(59,123,232,0.25);
      --purple:#8B3FD9;--purple-bg:rgba(139,63,217,0.1);--purple-border:rgba(139,63,217,0.25);
      --teal:#0FA88A;--teal-bg:rgba(15,168,138,0.1);--teal-border:rgba(15,168,138,0.25);
      --red:#C9274A;--red-bg:rgba(201,39,74,0.1);--red-border:rgba(201,39,74,0.25);
      --amber:#D4890A;--amber-bg:rgba(212,137,10,0.1);--amber-border:rgba(212,137,10,0.25);
      --line:rgba(240,239,255,0.07);
      --serif:'EB Garamond',Georgia,serif;
      --sans:'DM Sans',sans-serif;
    }
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:15px;line-height:1.6;overflow-x:hidden}
    .wrap{max-width:1000px;margin:0 auto;padding:0 52px}
    section{padding:88px 0;border-bottom:1px solid var(--line)}
    section:last-of-type{border-bottom:none}
    .reveal{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease}
    .reveal.visible{opacity:1;transform:translateY(0)}
    .d1{transition-delay:.07s!important}.d2{transition-delay:.14s!important}
    .d3{transition-delay:.21s!important}.d4{transition-delay:.28s!important}
    #hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:100px 52px 88px;position:relative;overflow:hidden}
    .hero-glow{position:absolute;top:-10%;right:-15%;width:800px;height:800px;background:radial-gradient(ellipse,rgba(139,63,217,0.12) 0%,rgba(59,123,232,0.06) 40%,transparent 70%);pointer-events:none}
    .hero-glow2{position:absolute;bottom:-20%;left:-10%;width:600px;height:600px;background:radial-gradient(ellipse,rgba(15,168,138,0.06) 0%,transparent 65%);pointer-events:none}
    .from-badge{display:inline-flex;align-items:center;gap:8px;background:var(--purple-bg);border:1px solid var(--purple-border);border-radius:100px;padding:5px 14px;font-size:11px;font-weight:500;color:var(--purple);letter-spacing:.4px;margin-bottom:36px;width:fit-content}
    .hero-label{font-size:11px;color:var(--text3);letter-spacing:1.8px;text-transform:uppercase;margin-bottom:16px;font-weight:500}
    #hero h1{font-family:var(--serif);font-size:clamp(46px,6vw,82px);font-weight:400;line-height:1.04;letter-spacing:-.5px;color:var(--text);max-width:860px;margin-bottom:28px}
    #hero h1 em{font-style:italic;color:var(--blue-light)}
    .hero-sub{font-size:17px;font-weight:300;color:var(--text2);max-width:520px;line-height:1.8;margin-bottom:52px}
    .hero-sub strong{color:var(--text);font-weight:500}
    .hero-stats{display:grid;grid-template-columns:1.7fr 1fr 1fr;gap:1px;background:var(--line);border:1px solid var(--line);border-radius:18px;overflow:hidden;max-width:740px}
    .hstat{background:var(--bg1);padding:26px 24px}
    .hstat-label{font-size:10px;color:var(--text3);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;font-weight:600}
    .hstat-rating-row{display:flex;align-items:baseline;gap:10px}
    .hstat-rating-val{font-family:var(--serif);font-size:56px;font-weight:400;line-height:1}
    .hstat-star{font-size:30px;line-height:1}
    .hstat-review-count{font-size:12px;color:var(--text3);margin-top:6px}
    .hstat-val{font-family:var(--serif);font-size:42px;font-weight:400;line-height:1}
    .hstat-sub{font-size:11px;color:var(--text3);margin-top:6px}
    .hstat-fraction{font-size:12px;color:var(--text3);margin-top:6px}
    .eyebrow{font-size:10px;font-weight:600;color:var(--blue);letter-spacing:2px;text-transform:uppercase;margin-bottom:14px}
    h2{font-family:var(--serif);font-size:clamp(32px,4.2vw,54px);font-weight:400;line-height:1.08;letter-spacing:-.3px;color:var(--text);margin-bottom:14px}
    h2 em{font-style:italic;color:var(--blue-light)}
    .section-sub{font-size:16px;color:var(--text2);font-weight:300;max-width:540px;line-height:1.75;margin-bottom:52px}
    .score-grid{display:grid;grid-template-columns:240px 1fr;gap:24px;align-items:start}
    .score-main{background:var(--bg1);border:1px solid var(--line);border-radius:20px;padding:32px;text-align:center}
    .score-ring{width:136px;height:136px;border-radius:50%;margin:0 auto 20px;display:flex;align-items:center;justify-content:center;position:relative}
    .score-ring::after{content:'';position:absolute;width:106px;height:106px;border-radius:50%;background:var(--bg1)}
    .score-num{position:relative;z-index:1;font-family:var(--serif);font-size:46px;color:var(--text);line-height:1}
    .score-label-sm{font-size:11px;color:var(--text3);margin-bottom:6px;letter-spacing:.5px}
    .score-verdict{font-family:var(--serif);font-size:20px;font-style:italic;margin-bottom:10px}
    .score-note{font-size:12px;color:var(--text3);line-height:1.65}
    .score-insights{display:flex;flex-direction:column;gap:0;border:1px solid var(--line);border-radius:18px;overflow:hidden}
    .si-row{display:grid;grid-template-columns:88px 1fr;border-bottom:1px solid var(--line);background:var(--bg1);transition:background .2s}
    .si-row:last-child{border-bottom:none}
    .si-row:hover{background:var(--bg2)}
    .si-stat{padding:20px 14px 20px 20px;display:flex;align-items:center;justify-content:center;border-right:1px solid var(--line)}
    .si-stat-val{font-family:var(--serif);font-size:22px;line-height:1;text-align:center}
    .si-text{padding:20px 22px}
    .si-headline{font-size:13px;font-weight:500;color:var(--text);margin-bottom:4px;line-height:1.45}
    .si-desc{font-size:12px;color:var(--text3);line-height:1.55}
    .dow-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:10px}
    .dow-col{display:flex;flex-direction:column;align-items:center;gap:8px}
    .dow-bar-wrap{width:100%;height:150px;background:var(--bg2);border-radius:8px;display:flex;align-items:flex-end;overflow:hidden}
    .dow-bar{width:100%;border-radius:8px 8px 0 0}
    .dow-bar.low{background:#2E7D5E}.dow-bar.mid{background:#4C6A9C}.dow-bar.high{background:#8B3050}
    .dow-label{font-size:11px;color:var(--text3);font-weight:500}
    .dow-pct{font-family:var(--serif);font-size:17px}
    .dow-pct.low{color:#3A9E77}.dow-pct.mid{color:#6B8DC4}.dow-pct.high{color:#C24070}
    .dow-total{font-size:10px;color:var(--text3)}
    .complaint-bars{display:flex;flex-direction:column;gap:16px;max-width:680px}
    .cbar-row{display:flex;align-items:center;gap:14px}
    .cbar-label{font-size:13px;color:var(--text);width:160px;flex-shrink:0}
    .cbar-track{flex:1;height:7px;background:var(--bg3);border-radius:4px;overflow:hidden}
    .cbar-fill{height:100%;border-radius:4px;background:#4C6A9C;transition:width 1.1s cubic-bezier(.4,0,.2,1)}
    .cbar-count{font-family:var(--serif);font-size:20px;color:var(--text);width:34px;text-align:right}
    .cbar-pct{font-size:11px;color:var(--text3);width:40px}
    .food-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
    .food-card{background:var(--bg1);border:1px solid var(--line);border-radius:16px;padding:24px}
    .food-card.high{border-color:var(--red-border)}.food-card.medium{border-color:var(--amber-border)}
    .food-name{font-family:var(--serif);font-size:23px;font-style:italic;color:var(--text);margin-bottom:4px}
    .food-meta{font-size:11px;color:var(--text3);margin-bottom:14px;letter-spacing:.4px;text-transform:uppercase;font-weight:600}
    .food-complaints{display:flex;flex-direction:column;gap:7px}
    .food-complaint{font-size:13px;color:var(--text2);padding:9px 14px;background:var(--bg2);border-radius:8px;line-height:1.55}
    .insight-cards{display:flex;flex-direction:column;gap:20px}
    .insight-card{background:var(--bg1);border:1px solid var(--line);border-radius:20px;padding:32px;display:grid;grid-template-columns:1fr 120px;gap:28px;align-items:start}
    .ic-num{font-size:10px;letter-spacing:1.8px;font-weight:600;text-transform:uppercase;margin-bottom:12px}
    .insight-card h3{font-family:var(--serif);font-size:24px;font-weight:400;color:var(--text);line-height:1.22;margin-bottom:14px;letter-spacing:-.1px}
    .insight-card p{font-size:14px;color:var(--text2);line-height:1.75}
    .ic-tags{display:flex;gap:7px;flex-wrap:wrap;margin-top:18px}
    .ic-tag{padding:4px 11px;border-radius:100px;font-size:11px;font-weight:500;background:var(--bg2);border:1px solid var(--line);color:var(--text3)}
    .ic-big{text-align:right}
    .ic-big-val{font-family:var(--serif);font-size:54px;line-height:1;letter-spacing:-2px}
    .ic-big-label{font-size:11px;color:var(--text3);margin-top:6px;line-height:1.4}
    .reviews-grid{display:flex;flex-direction:column;gap:14px}
    .review-card{background:var(--bg1);border:1px solid var(--line);border-radius:16px;padding:26px}
    .rc-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
    .rc-meta{display:flex;align-items:center;gap:12px}
    .rc-avatar{width:34px;height:34px;border-radius:50%;background:var(--bg3);display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-size:15px;color:var(--text2);font-style:italic}
    .rc-name{font-size:13px;font-weight:500;color:var(--text)}
    .rc-source{font-size:11px;color:var(--text3);margin-top:2px}
    .rc-rating{font-family:var(--serif);font-size:13px;font-style:italic}
    .rc-body{font-size:14px;color:var(--text2);line-height:1.75;margin-bottom:16px}
    .rc-footer{display:flex;align-items:center;justify-content:space-between}
    .rc-date{font-size:11px;color:var(--text3)}
    .rc-no-reply{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:500}
    .rc-no-reply::before{content:'';display:inline-block;width:5px;height:5px;border-radius:50%;background:currentColor}
    #cta{padding:100px 0;border-bottom:none}
    .cta-box{background:var(--bg1);border:1px solid var(--blue-border);border-radius:24px;padding:72px 52px;position:relative;overflow:hidden;text-align:center}
    .cta-glow{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:700px;height:500px;background:radial-gradient(ellipse,rgba(139,63,217,0.08) 0%,rgba(59,123,232,0.05) 40%,transparent 70%);pointer-events:none}
    #cta h2{margin-bottom:22px}
    #cta p{font-size:18px;color:var(--text2);font-weight:300;line-height:1.75;max-width:500px;margin:0 auto 44px}
    .cta-actions{display:flex;align-items:center;justify-content:center;gap:14px;flex-wrap:wrap}
    .btn-main{background:var(--text);color:var(--bg);padding:16px 38px;border-radius:100px;font-size:14px;font-weight:600;text-decoration:none;display:inline-block;transition:opacity .2s,transform .2s}
    .btn-main:hover{opacity:.88;transform:translateY(-2px)}
    .btn-outline{background:transparent;border:1px solid var(--line);color:var(--text2);padding:16px 32px;border-radius:100px;font-size:14px;text-decoration:none;display:inline-block;transition:border-color .2s,color .2s}
    .btn-outline:hover{border-color:var(--text2);color:var(--text)}
    .cta-fine{font-size:12px;color:var(--text3);margin-top:24px}
  </style>
</head>
<body>

<!-- HERO -->
<div id="hero">
  <div class="hero-glow"></div>
  <div class="hero-glow2"></div>
  <div class="wrap">
    <div class="from-badge reveal">Prepared by Olly, AI Reputation Intelligence</div>
    <div class="hero-label reveal d1"><%= d.brand_name %> &middot; <%= d.platform %> &middot; <%= d.total_reviews_analysed %> reviews analysed</div>
    <h1 class="reveal d2">
      <%= dc.hero_headline_line1 %><br>
      <em><%= dc.hero_headline_line2_italic %></em>
    </h1>
    <p class="hero-sub reveal d3"><%= dc.hero_subtext %></p>
    <div class="hero-stats reveal d4">
      <div class="hstat">
        <div class="hstat-label">Avg Rating</div>
        <div class="hstat-rating-row">
          <div class="hstat-rating-val" style="color:<%= rc %>"><%= d.avg_rating %></div>
          <div class="hstat-star" style="color:<%= rc %>">&#9733;</div>
        </div>
        <div class="hstat-review-count">Out of 5.0, <%= d.all_reviews_count %> total reviews</div>
      </div>
      <div class="hstat">
        <div class="hstat-label">Negative Reviews</div>
        <div class="hstat-val" style="color:#C9274A"><%= d.negative_count %></div>
        <div class="hstat-fraction">of <%= d.total_reviews_analysed %>, 1&#9733; 2&#9733; 3&#9733;</div>
      </div>
      <div class="hstat">
        <div class="hstat-label">Response Rate</div>
        <div class="hstat-val" style="color:#C9274A"><%= d.response_rate_pct %>%</div>
        <div class="hstat-sub">0 of <%= d.total_reviews_analysed %> answered</div>
      </div>
    </div>
  </div>
</div>

<!-- REPUTATION SCORE -->
<section>
  <div class="wrap">
    <div class="eyebrow reveal">Reputation Score</div>
    <h2 class="reveal d1"><%= dc.score_section_title %></h2>
    <p class="section-sub reveal d2">Not just a star average. Built from complaint frequency, response rate, and consistency.</p>
    <div class="score-grid">
      <div class="score-main reveal d1">
        <div class="score-label-sm">Olly Reputation Score</div>
        <div class="score-ring" style="background:<%= ring %>">
          <div class="score-num"><%= d.olly_score %></div>
        </div>
        <div class="score-verdict" style="color:<%= vc %>"><%= d.olly_verdict %></div>
        <div class="score-note"><%= scoreNote(d.olly_score) %></div>
      </div>
      <div class="score-insights reveal d2">
        <% d.score_insights.forEach(function(si) { %>
        <div class="si-row">
          <div class="si-stat">
            <div class="si-stat-val" style="color:<%= statColor(si.stat_type) %>"><%= si.stat %></div>
          </div>
          <div class="si-text">
            <div class="si-headline"><%= si.headline %></div>
            <div class="si-desc"><%= si.desc %></div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </div>
</section>

<!-- WEEKLY PATTERN -->
<% if (showDow) { %>
<section>
  <div class="wrap">
    <div class="eyebrow reveal">Weekly Pattern</div>
    <h2 class="reveal d1"><%= dc.dow_section_title %></h2>
    <p class="section-sub reveal d2"><%= dc.dow_section_sub %></p>
    <div class="dow-grid reveal d3" id="dow-chart">
      <% d.dow_breakdown.forEach(function(day) {
        var cls = dowBarClass(day.complaint_pct);
        var barH = maxDow > 0 ? Math.round((day.complaint_pct / maxDow) * 100) : 0;
      %>
      <div class="dow-col">
        <div class="dow-bar-wrap">
          <div class="dow-bar <%= cls %>" style="height:0%" data-h="<%= barH %>%"></div>
        </div>
        <div class="dow-label"><%= day.day %></div>
        <div class="dow-pct <%= cls %>"><%= day.complaint_pct %>%</div>
        <div class="dow-total"><%= day.total %> reviews</div>
      </div>
      <% }); %>
    </div>
    <div style="margin-top:28px;padding:24px 28px;background:var(--amber-bg);border:1px solid var(--amber-border);border-radius:14px;" class="reveal d4">
      <div style="font-size:10px;font-weight:600;color:var(--amber);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:10px;">What this likely means</div>
      <p style="font-size:14px;color:var(--text2);line-height:1.75;"><%= dc.dow_callout %></p>
    </div>
  </div>
</section>
<% } %>

<!-- COMPLAINT BREAKDOWN -->
<section>
  <div class="wrap">
    <div class="eyebrow reveal">Complaint Breakdown</div>
    <h2 class="reveal d1"><%= dc.complaints_section_title %></h2>
    <p class="section-sub reveal d2"><%= dc.complaints_section_sub %></p>
    <div class="complaint-bars">
      <% d.complaint_categories.forEach(function(cat) {
        var w = maxCat > 0 ? Math.round((cat.count / maxCat) * 100) : 0;
      %>
      <div class="cbar-row reveal">
        <div class="cbar-label"><%= cat.label %></div>
        <div class="cbar-track">
          <div class="cbar-fill" style="width:0%" data-width="<%= w %>%"></div>
        </div>
        <div class="cbar-count"><%= cat.count %></div>
        <div class="cbar-pct"><%= cat.pct %>%</div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- MENU INTELLIGENCE -->
<% if (showMenu) { %>
<section>
  <div class="wrap">
    <div class="eyebrow reveal">Menu Intelligence</div>
    <h2 class="reveal d1"><%= dc.menu_section_title %></h2>
    <p class="section-sub reveal d2"><%= dc.menu_section_sub %></p>
    <div class="food-grid">
      <% d.menu_complaints.forEach(function(item) { %>
      <div class="food-card <%= item.severity %> reveal">
        <div class="food-name"><%= item.item %></div>
        <div class="food-meta"><%= item.complaint_count %> complaints &middot; <%= item.severity %> severity</div>
        <div class="food-complaints">
          <% item.sample_quotes.forEach(function(q) { %>
          <div class="food-complaint"><%= q %></div>
          <% }); %>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- KEY FINDINGS -->
<section>
  <div class="wrap">
    <div class="eyebrow reveal">Key Findings</div>
    <h2 class="reveal d1"><%= d.key_findings.length %> things hiding <em>in plain sight.</em></h2>
    <p class="section-sub reveal d2"><%= dc.findings_section_sub %></p>
    <div class="insight-cards">
      <% d.key_findings.filter(function(f){ return f != null; }).forEach(function(f) {
        var sc = severityColor(f.severity);
      %>
      <div class="insight-card reveal" style="border-color:<%= sc %>20">
        <div>
          <div class="ic-num" style="color:<%= sc %>">Finding <%= f.number %></div>
          <h3><%= f.title %></h3>
          <p><%= f.body %></p>
          <div class="ic-tags">
            <% f.tags.forEach(function(tag) { %>
            <span class="ic-tag"><%= tag %></span>
            <% }); %>
          </div>
        </div>
        <div class="ic-big">
          <div class="ic-big-val" style="color:<%= sc %>"><%= f.big_number %></div>
          <div class="ic-big-label"><%= f.big_label %></div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- UNANSWERED REVIEWS -->
<section>
  <div class="wrap">
    <div class="eyebrow reveal">From Your Reviews</div>
    <h2 class="reveal d1"><%= dc.unanswered_section_title %></h2>
    <div class="reviews-grid">
      <% d.unanswered_reviews.forEach(function(r) { %>
      <div class="review-card reveal" style="border-color:<%= reviewBorderColor(r.rating) %>">
        <div class="rc-top">
          <div class="rc-meta">
            <div class="rc-avatar"><%= r.profile_initial %></div>
            <div>
              <div class="rc-name"><%= r.profile_name %></div>
              <div class="rc-source"><%= d.platform %> &middot; <%= r.date %></div>
            </div>
          </div>
          <div class="rc-rating" style="color:<%= reviewRatingColor(r.rating) %>"><%= r.rating %> / 5</div>
        </div>
        <p class="rc-body"><%= r.review_text %></p>
        <div class="rc-footer">
          <div class="rc-date"><%= r.days_since_posted %> days ago</div>
          <div class="rc-no-reply" style="color:#C9274A">No response from <%= d.brand_name %></div>
        </div>
      </div>
      <% }); %>
    </div>
    <div style="margin-top:18px;padding:20px 26px;background:var(--bg1);border:1px solid var(--line);border-radius:14px;display:flex;align-items:center;justify-content:space-between;gap:24px;">
      <p style="font-size:13px;color:var(--text2);line-height:1.6;"><strong style="color:var(--text)">These are <%= d.unanswered_reviews.length %> of <%= d.negative_count %>.</strong> Olly can respond to all of them in your brand voice.</p>
      <a href="https://tryolly.com" style="white-space:nowrap;background:linear-gradient(135deg,#3B7BE8,#8B3FD9);color:#fff;padding:10px 22px;border-radius:100px;font-size:13px;font-weight:600;text-decoration:none;flex-shrink:0;">Get started free</a>
    </div>
  </div>
</section>

<!-- CTA -->
<section id="cta">
  <div class="wrap">
    <div class="cta-box reveal">
      <div class="cta-glow"></div>
      <h2><%= dc.cta_headline_line1 %><br><em><%= dc.cta_headline_line2_italic %></em></h2>
      <p><%= dc.cta_subtext %></p>
      <div class="cta-actions">
        <a href="https://tryolly.com" class="btn-main">Download Olly and get started for FREE</a>
        <a href="https://tryolly.com/demo" class="btn-outline">Book a demo</a>
      </div>
      <div class="cta-fine">No credit card. No setup fees. Connect in under 2 minutes.</div>
    </div>
  </div>
</section>

<script>
  const obs=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('visible')}),{threshold:.06,rootMargin:'0px 0px -20px 0px'});
  document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
  const dowObs=new IntersectionObserver(e=>e.forEach(x=>{
    if(x.isIntersecting){x.target.querySelectorAll('.dow-bar').forEach(b=>setTimeout(()=>{b.style.height=b.dataset.h},80));dowObs.unobserve(x.target);}
  }),{threshold:.2});
  const dc2=document.getElementById('dow-chart');if(dc2)dowObs.observe(dc2);
  const barObs=new IntersectionObserver(e=>e.forEach(x=>{
    if(x.isIntersecting){const f=x.target.querySelector('.cbar-fill');if(f)setTimeout(()=>{f.style.width=f.dataset.width},100);barObs.unobserve(x.target);}
  }),{threshold:.3});
  document.querySelectorAll('.cbar-row').forEach(el=>barObs.observe(el));
</script>
</body>
</html>
